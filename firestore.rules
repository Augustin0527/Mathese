rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Utilisateurs ──────────────────────────────────────────────────────────
    // Chaque utilisateur lit/modifie son propre profil
    // Un directeur peut lire les profils de ses étudiants
    match /utilisateurs/{uid} {
      allow read: if request.auth != null && (
        request.auth.uid == uid ||
        resource.data.get('directeurId', '') == request.auth.uid ||
        resource.data.get('codirecteurId', '') == request.auth.uid
      );
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;

      // Articles personnels
      match /articles/{articleId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Objectifs de planification
      match /objectifs/{objectifId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Journal
      match /journal/{entryId} {
        allow read: if request.auth != null && (
          request.auth.uid == uid ||
          get(/databases/$(database)/documents/utilisateurs/$(uid)).data.get('directeurId', '') == request.auth.uid
        );
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      // Chapitres
      match /chapitres/{chapitreId} {
        allow read: if request.auth != null && (
          request.auth.uid == uid ||
          get(/databases/$(database)/documents/utilisateurs/$(uid)).data.get('directeurId', '') == request.auth.uid
        );
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ── Invitations ───────────────────────────────────────────────────────────
    match /invitations/{invId} {
      // Lire : l'envoyeur ou le destinataire (par email)
      allow read: if request.auth != null && (
        resource.data.get('fromUid', '') == request.auth.uid ||
        resource.data.get('toEmail', '') == request.auth.token.email
      );
      allow create: if request.auth != null;
      // Mettre à jour (accepter/refuser) : seulement le destinataire
      allow update: if request.auth != null &&
        resource.data.get('toEmail', '') == request.auth.token.email;
      allow delete: if request.auth != null &&
        resource.data.get('fromUid', '') == request.auth.uid;
    }

    // ── Pomodoro participants ─────────────────────────────────────────────────
    match /pomodoro_participants/{uid} {
      // Tout utilisateur authentifié peut lire la liste (présence)
      allow read: if request.auth != null;
      // Chaque utilisateur gère sa propre entrée
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Pomodoro chat ─────────────────────────────────────────────────────────
    match /pomodoro_chat/{msgId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.resource.data.get('uid', '') == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Recommandations (directeur → étudiant) ────────────────────────────────
    match /recommandations/{recId} {
      allow read: if request.auth != null && (
        resource.data.get('etudiantId', '') == request.auth.uid ||
        resource.data.get('directeurId', '') == request.auth.uid
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        resource.data.get('etudiantId', '') == request.auth.uid ||
        resource.data.get('directeurId', '') == request.auth.uid
      );
      allow delete: if request.auth != null &&
        resource.data.get('directeurId', '') == request.auth.uid;
    }
  }
}
